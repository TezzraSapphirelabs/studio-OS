rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/conversations/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/conversations/{conversationId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/notes/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Returns the exact role for write operations (bypasses query planner limitations)
    function getProjectRole(projectId) {
      return (exists(/databases/$(database)/documents/projects/$(projectId)) && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid)
        ? 'owner'
        : (exists(/databases/$(database)/documents/members/$(projectId + "_" + request.auth.uid))
           ? get(/databases/$(database)/documents/members/$(projectId + "_" + request.auth.uid)).data.role
           : 'none');
    }

    function isRole(projectId, allowedRoles) {
      return getProjectRole(projectId) in allowedRoles;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: Check if user is a member of a project ──
    function isProjectMember(projectId) {
      let isOwner = get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid;
      let isMember = request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberUids;
      return isOwner || isMember;
    }

    // ── Helper: Check if user is a member of a workspace ──
    function isWorkspaceMember(workspaceId) {
      let isOwner = workspaceId == request.auth.uid;
      let isMember = exists(/databases/$(database)/documents/workspaceMembers/$(workspaceId + '_' + request.auth.uid));
      return isOwner || isMember;
    }

    match /projects/{projectId} {
      allow read: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        ('memberUids' in resource.data && request.auth.uid in resource.data.memberUids)
      );
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null && (
        isRole(projectId, ['owner'])
        || (isRole(projectId, ['admin']) && request.resource.data.ownerUid == resource.data.ownerUid)
        // Allow a new member to add themselves to memberUids after accepting an invite
        || (exists(/databases/$(database)/documents/members/$(projectId + "_" + request.auth.uid))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']))
      );
      allow delete: if request.auth != null && isRole(projectId, ['owner']);
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null && isProjectMember(resource.data.projectId);
      allow create: if request.auth != null && isRole(request.resource.data.projectId, ['owner', 'admin', 'member']);
      allow update: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin'])
        // Member can update if they are the current assignee, OR if they are assigning it to themselves
        || (isRole(resource.data.projectId, ['member']) && (
             (resource.data.assigneeId == request.auth.uid) || 
             (request.resource.data.assigneeId == request.auth.uid)
           ))
      );
      allow delete: if request.auth != null && isRole(resource.data.projectId, ['owner', 'admin']);
    }

    match /activities/{activityId} {
      allow read: if request.auth != null && (
        isProjectMember(resource.data.projectId) || 
        isWorkspaceMember(resource.data.projectId) ||
        ('workspaceId' in resource.data && isWorkspaceMember(resource.data.workspaceId)) ||
        resource.data.ownerUid == request.auth.uid
      );
      allow create: if request.auth != null && (
        isRole(request.resource.data.projectId, ['owner', 'admin', 'member']) ||
        isWorkspaceMember(request.resource.data.projectId) ||
        request.resource.data.ownerUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin']) || 
        resource.data.ownerUid == request.auth.uid
      );
    }

    match /members/{memberDocId} {
      allow read: if request.auth != null && (isProjectMember(resource.data.projectId) || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || isRole(request.resource.data.projectId, ['owner', 'admin'])
      );
      allow update: if request.auth != null && (
        isRole(resource.data.projectId, ['owner']) || 
        (isRole(resource.data.projectId, ['admin']) && request.resource.data.role != 'owner' && resource.data.role != 'owner')
      );
      allow delete: if request.auth != null && (
        isRole(resource.data.projectId, ['owner']) || 
        (isRole(resource.data.projectId, ['admin']) && resource.data.role != 'owner') ||
        resource.data.userId == request.auth.uid 
      );
    }

    match /files/{fileId} {
      allow read: if request.auth != null && isProjectMember(resource.data.projectId);
      allow create: if request.auth != null && isProjectMember(request.resource.data.projectId);
      allow update: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin']) || resource.data.ownerUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin']) || resource.data.ownerUid == request.auth.uid
      );
    }

    match /folders/{folderId} {
      allow read: if request.auth != null && isProjectMember(resource.data.projectId);
      allow create: if request.auth != null && isProjectMember(request.resource.data.projectId);
      allow update: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin']) || resource.data.ownerUid == request.auth.uid
      );
      allow delete: if request.auth != null && (
        isRole(resource.data.projectId, ['owner', 'admin']) || resource.data.ownerUid == request.auth.uid
      );
    }

    match /projectInvites/{inviteId} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.inviteeEmail || isProjectMember(resource.data.projectId)
      );
      allow create: if request.auth != null && isRole(request.resource.data.projectId, ['owner', 'admin']);
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.inviteeEmail || isRole(resource.data.projectId, ['owner', 'admin'])
      );
      allow delete: if request.auth != null && (
        request.auth.token.email == resource.data.inviteeEmail || isRole(resource.data.projectId, ['owner', 'admin'])
      );
    }

    // ── Phase 6 Extensions ─────────────────────────────────────

    match /workspaceMembers/{memberId} {
      allow read: if request.auth != null && isWorkspaceMember(resource.data.workspaceId);
      allow create, update, delete: if request.auth != null && (
        request.resource.data.workspaceId == request.auth.uid || 
        resource.data.workspaceId == request.auth.uid ||
        resource.data.userId == request.auth.uid // Allow users to leave workspace
      );
    }

    match /workspaceInvites/{inviteId} {
      allow read: if request.auth != null && (
        isWorkspaceMember(resource.data.workspaceId) || 
        request.auth.token.email == resource.data.inviteeEmail
      );
      allow create, update, delete: if request.auth != null && (
        request.resource.data.workspaceId == request.auth.uid || 
        resource.data.workspaceId == request.auth.uid ||
        request.auth.token.email == resource.data.inviteeEmail
      );
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /comments/{commentId} {
      allow read: if request.auth != null && (
        ('projectId' in resource.data && (isProjectMember(resource.data.projectId) || isWorkspaceMember(resource.data.projectId))) ||
        resource.data.authorId == request.auth.uid
      );
      allow create: if request.auth != null && (
        ('projectId' in request.resource.data && (isProjectMember(request.resource.data.projectId) || isWorkspaceMember(request.resource.data.projectId))) ||
        request.resource.data.authorId == request.auth.uid
      );
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // ── Workspaces ─────────────────────────────────────────────
    // Note: workspaceId is currently the ownerUid
    match /workspaces/{workspaceId} {
      allow read: if isAuthenticated() && isWorkspaceMember(workspaceId);
      allow write: if isAuthenticated() && workspaceId == request.auth.uid;
    }
  }
}
